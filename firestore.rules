rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lecture publique pour tout le monde
    match /{document=**} {
      allow read: if true;
    }
    
    // Fonctions helper pour la clarté
    function isAdmin() {
      return request.auth != null && 
             (request.auth.token.email == "taigermboumba@gmail.com" || 
              request.auth.token.email == "taigermboumba@gmail.com"); // Doublon au cas où
    }

    match /projects/{project} {
      allow create, update, delete: if isAdmin();
    }
    
    match /settings/{setting} {
      allow create, update, delete: if isAdmin();
    }

    match /skills/{skill} {
      allow create, update, delete: if isAdmin();
    }

    match /features/{feature} {
      allow create, update, delete: if isAdmin();
    }
    
    match /stats/{stat} {
      allow read, write: if true; 
    }
  }
}
